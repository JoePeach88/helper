name: Create {module} Release

on:
  push:
    tags:
      - '*.*'

jobs:
  build:
    name: Create Release
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - name: "[Step 1] Checkout code"
        uses: actions/checkout@v2
  
      - name: "[Step 2] Create Release"
        id: create_release
        uses: actions/create-release@v1
        env:
          GITHUB_TOKEN: ${{{{ secrets.GITHUB_TOKEN }}}}
        with:
          tag_name: ${{{{ github.ref }}}}
          release_name: {module} v.${{{{ github.ref }}}}
          body_path: ./CHANGELOG.md
          draft: false
          prerelease: false
